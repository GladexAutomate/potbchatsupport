{
  "name": "TicketMessage",
  "type": "object",
  "properties": {
    "ticket_id": {
      "type": "string",
      "description": "Reference to Ticket id"
    },
    "sender_email": {
      "type": "string"
    },
    "sender_name": {
      "type": "string"
    },
    "sender_role": {
      "type": "string",
      "enum": [
        "customer",
        "staff"
      ],
      "default": "customer"
    },
    "message": {
      "type": "string"
    },
    "message_type": {
      "type": "string",
      "enum": [
        "regular",
        "resolution_request",
        "system_auto_close"
      ],
      "default": "regular",
      "description": "Type of message for special rendering"
    },
    "is_internal": {
      "type": "boolean",
      "default": false,
      "description": "If true, visible to staff only"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of any attached files"
    }
  },
  "required": [
    "ticket_id",
    "message",
    "sender_role"
  ]
}