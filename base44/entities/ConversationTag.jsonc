{
  "name": "ConversationTag",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Tag name"
    },
    "color": {
      "type": "string",
      "description": "Hex color for the tag",
      "default": "#6366f1"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether the tag is active"
    }
  },
  "required": [
    "name"
  ]
}